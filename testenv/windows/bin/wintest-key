#!/usr/bin/env bash
# Send a key chord to the guest via QMP. Each argument is a QEMU QKeyCode;
# multiple arguments are pressed together as one chord, then released.
#
# Examples:
#   wintest-key ret              # Enter
#   wintest-key ctrl c           # Ctrl+C
#   wintest-key alt f4           # Alt+F4
#   wintest-key meta_l           # Windows key (open Start)
#
# Common QKeyCodes: ret esc tab spc backspace delete up down left right
#   home end pgup pgdn ins f1..f12 ctrl alt shift meta_l a..z 0..9
source "$(dirname "${BASH_SOURCE[0]}")/_common.sh"

is_running || die "VM not running — start it with wintest-start"
(( $# >= 1 )) || die "usage: wintest-key <qkeycode> [qkeycode...]   (e.g. ctrl c)"

keys=$(printf '%s\n' "$@" | jq -R . | jq -sc 'map({type:"qcode",data:.})')
wintest_qmp "$(jq -nc --argjson k "$keys" \
  '{execute:"send-key",arguments:{keys:$k}}')" >/dev/null
log "sent key: $*"

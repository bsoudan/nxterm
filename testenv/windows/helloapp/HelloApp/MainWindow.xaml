<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HelloApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Hello App">

    <StackPanel Orientation="Vertical" Spacing="12" Padding="24" VerticalAlignment="Center">
        <TextBox x:Name="NameBox"
                 AutomationProperties.AutomationId="NameBox"
                 Header="Name"
                 PlaceholderText="Enter your name"
                 KeyDown="NameBox_KeyDown"
                 Width="320" />
        <Button x:Name="GreetButton"
                AutomationProperties.AutomationId="GreetButton"
                Content="Greet"
                Click="GreetButton_Click" />
        <TextBlock x:Name="GreetingText"
                   AutomationProperties.AutomationId="GreetingText"
                   FontSize="20"
                   Text="" />
    </StackPanel>

</Window>

<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Nx2Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml">

    <Grid Background="#000000">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <canvas:CanvasControl
            x:Name="TerminalCanvas"
            Grid.Row="0"
            Loaded="TerminalCanvas_Loaded"
            Draw="TerminalCanvas_Draw"
            SizeChanged="TerminalCanvas_SizeChanged"
            IsTabStop="True"
            KeyDown="TerminalCanvas_KeyDown" />

        <Border Grid.Row="1" Background="#1E1E1E" Padding="8,2">
            <TextBlock x:Name="StatusBar" Foreground="#B0B0B0" FontSize="12"
                       FontFamily="Consolas" Text="starting…" />
        </Border>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NxtermGui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:ui="using:NxtermGui.Ui"
    Title="nxterm">

    <Grid Background="#0C0C0C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tab strip in the title bar (Windows Terminal style). The whole row is
             the draggable caption; the system caption buttons sit over the
             right reserve column. -->
        <Grid Grid.Row="0" x:Name="AppTitleBar" Background="#1B1B1B" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0"
                          VerticalAlignment="Bottom"
                          HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="TabStrip">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="ui:TabItem">
                            <!-- A Button (not a Border) so it stays interactive
                                 inside the title-bar drag region. -->
                            <Button Click="Tab_Click"
                                    Background="{x:Bind Background, Mode=OneWay}"
                                    BorderThickness="0"
                                    CornerRadius="6,6,0,0"
                                    Margin="2,8,0,0"
                                    Padding="12,4,6,4"
                                    AutomationProperties.AutomationId="TerminalTab"
                                    AutomationProperties.Name="{x:Bind Title, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                               Foreground="{x:Bind Foreground, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               MaxWidth="180"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button Click="TabClose_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="10"
                                            Foreground="#9A9A9A"
                                            AutomationProperties.AutomationId="CloseTab"
                                            Content="&#xE8BB;" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button x:Name="NewTabButton"
                        Click="NewTab_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="4,0,2,4"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        Foreground="#C8C8C8"
                        AutomationProperties.AutomationId="NewTabButton"
                        AutomationProperties.Name="New tab"
                        Content="&#xE710;" />
                <Button x:Name="MenuButton"
                        Click="MenuButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="0,0,6,4"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        Foreground="#C8C8C8"
                        AutomationProperties.AutomationId="MenuButton"
                        AutomationProperties.Name="Commands"
                        Content="&#xE712;" />
            </StackPanel>
            <!-- reserve space under the system caption buttons -->
            <Border Grid.Column="2" Background="Transparent" />
        </Grid>

        <!-- Terminal viewport. The AutomationProperties.AutomationId gives WAD a
             handle on the otherwise UIA-opaque Win2D canvas — necessary for the
             clipboard test, which sends Ctrl+Shift+C via WAD's element-targeted
             key endpoint (session-level /keys and QMP keys do not reach a
             WAD-launched app's canvas). -->
        <canvas:CanvasControl Grid.Row="1"
                              x:Name="TerminalCanvas"
                              IsTabStop="True"
                              AutomationProperties.AutomationId="TerminalCanvas"
                              AutomationProperties.Name="Terminal"
                              Draw="TerminalCanvas_Draw"
                              Loaded="TerminalCanvas_Loaded"
                              PointerPressed="TerminalCanvas_PointerPressed"
                              PointerMoved="TerminalCanvas_PointerMoved"
                              PointerReleased="TerminalCanvas_PointerReleased"
                              PointerWheelChanged="TerminalCanvas_PointerWheelChanged"
                              SizeChanged="TerminalCanvas_SizeChanged"
                              ClearColor="#0C0C0C" />

        <!-- Status bar -->
        <Grid Grid.Row="2" Background="#1B1B1B" Padding="10,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusLeft" Foreground="#B0B0B0" FontSize="12"
                       AutomationProperties.AutomationId="StatusLeft" />
            <TextBlock Grid.Column="1" x:Name="LastInput" Foreground="#5A5A5A" FontSize="11"
                       Margin="0,0,16,0" MaxWidth="220" TextTrimming="CharacterEllipsis"
                       AutomationProperties.AutomationId="LastInput" />
            <TextBlock Grid.Column="2" x:Name="ActiveRegionId" Foreground="#6A6A6A" FontSize="12"
                       Margin="0,0,16,0" MaxWidth="220" TextTrimming="CharacterEllipsis"
                       AutomationProperties.AutomationId="ActiveRegionId" />
            <TextBlock Grid.Column="3" x:Name="StatusRight" Foreground="#B0B0B0" FontSize="12"
                       AutomationProperties.AutomationId="StatusRight" />
        </Grid>

        <!-- Connect dialog overlay: shown when launched with no endpoint, or
             reopened via Ctrl+Shift+O. Spans all rows so it covers the chrome. -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              x:Name="ConnectDialog"
              Background="#E60C0C0C"
              Visibility="Collapsed"
              AutomationProperties.AutomationId="ConnectDialog">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Width="360">
                <TextBlock Text="Connect to nxtermd" Foreground="#E0E0E0" FontSize="18"
                           HorizontalAlignment="Center" />
                <TextBox x:Name="EndpointBox"
                         PlaceholderText="host:port"
                         AutomationProperties.AutomationId="EndpointBox"
                         AutomationProperties.Name="Endpoint" />
                <Button x:Name="ConnectButton"
                        Content="Connect"
                        HorizontalAlignment="Center"
                        Click="ConnectButton_Click"
                        AutomationProperties.AutomationId="ConnectButton" />
                <TextBlock x:Name="ConnectError" Foreground="#E0846A" FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Command palette overlay (Ctrl+Shift+P or the menu button). Commands
             are buttons so WinAppDriver can find + invoke them by AutomationId. -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              x:Name="CommandPalette"
              Background="#E60C0C0C"
              Visibility="Collapsed"
              AutomationProperties.AutomationId="CommandPalette">
            <Border Background="#1B1B1B" CornerRadius="8" Padding="8" Width="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#3A3A3A" BorderThickness="1">
                <StackPanel Spacing="2">
                    <TextBlock Text="Commands" Foreground="#9A9A9A" FontSize="13" Margin="6,2,0,6"
                               AutomationProperties.AutomationId="CommandPaletteTitle" />
                    <Button Content="New tab" Tag="new-tab" Click="Command_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0" Foreground="#E0E0E0"
                            AutomationProperties.AutomationId="CmdNewTab" />
                    <Button Content="Close tab" Tag="close-tab" Click="Command_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0" Foreground="#E0E0E0"
                            AutomationProperties.AutomationId="CmdCloseTab" />
                    <Button Content="Switch session…" Tag="sessions" Click="Command_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0" Foreground="#E0E0E0"
                            AutomationProperties.AutomationId="CmdSessions" />
                    <Button Content="Connect…" Tag="connect" Click="Command_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0" Foreground="#E0E0E0"
                            AutomationProperties.AutomationId="CmdConnect" />
                    <Button Content="Help" Tag="help" Click="Command_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0" Foreground="#E0E0E0"
                            AutomationProperties.AutomationId="CmdHelp" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Help overlay (the "Help" command). -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              x:Name="HelpOverlay"
              Background="#E60C0C0C"
              Visibility="Collapsed"
              AutomationProperties.AutomationId="HelpOverlay">
            <Border Background="#1B1B1B" CornerRadius="8" Padding="16" Width="460"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#3A3A3A" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Keyboard shortcuts" Foreground="#E0E0E0" FontSize="16"
                               AutomationProperties.AutomationId="HelpTitle" />
                    <TextBlock Text="Ctrl+Shift+P     Command palette" Foreground="#C0C0C0" FontFamily="Consolas" />
                    <TextBlock Text="Ctrl+Shift+O     Connect…" Foreground="#C0C0C0" FontFamily="Consolas" />
                    <TextBlock Text="Ctrl+Shift+C     Copy selection" Foreground="#C0C0C0" FontFamily="Consolas" />
                    <TextBlock Text="Ctrl+Shift+V     Paste" Foreground="#C0C0C0" FontFamily="Consolas" />
                    <TextBlock Text="Esc              Close overlay" Foreground="#C0C0C0" FontFamily="Consolas" />
                    <Button Content="Close" Click="HelpClose_Click" HorizontalAlignment="Right"
                            AutomationProperties.AutomationId="HelpClose" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Session picker overlay (the "Switch session…" command). Each session
             is a button whose AutomationId is the session name, so WinAppDriver
             can select a specific session by id. -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              x:Name="SessionPicker"
              Background="#E60C0C0C"
              Visibility="Collapsed"
              AutomationProperties.AutomationId="SessionPicker">
            <Border Background="#1B1B1B" CornerRadius="8" Padding="8" Width="420" MaxHeight="480"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#3A3A3A" BorderThickness="1">
                <StackPanel Spacing="2">
                    <TextBlock Text="Sessions" Foreground="#9A9A9A" FontSize="13" Margin="6,2,0,6"
                               AutomationProperties.AutomationId="SessionPickerTitle" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                        <ItemsControl x:Name="SessionList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Button Content="{x:Bind}" Tag="{x:Bind}" Click="Session_Click"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Background="Transparent" BorderThickness="0" Foreground="#E0E0E0"
                                            AutomationProperties.AutomationId="{x:Bind}"
                                            AutomationProperties.Name="{x:Bind}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</Window>
